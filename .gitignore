# Centralized security scan workflows + repo onboarding tooling.
#
# Consumer repos get thin caller stubs that invoke reusable workflows from
# this repo. Branch protection is applied via a dedicated ruleset driven by
# config profiles.

.DS_Store
/tmp/
*.before.json
*.after.json

# Operator-local configs (secrets paths, local clones)
/configs/local/

# Dot-dirs that are local/agent/editor only — never commit.
# Keep `.github/` tracked (Actions workflows).
/.plan/
/.handoff/
/.vscode/
/.cursor/
/.claude/
/.skills/
/.orchestra/
/.tickets/
/.env
/.env.*

# Python
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
