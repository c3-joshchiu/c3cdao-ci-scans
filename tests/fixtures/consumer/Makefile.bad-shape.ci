# Lint fixture contract variant: ci-manifest is valid JSON but off the
# required shape — images[0] missing dockerfile/context, chart missing
# keys, health absent (ci-contract-manifest must fire, blocking).

SHELL := /bin/bash

.PHONY: ci-manifest ci-build ci-secctx ci-smoke-env

ci-manifest:
	@echo '{"images": [{"name": "backend"}], "chart": {"path": "helm/app"}}'

ci-build:
	@echo noop

ci-secctx:
	@echo noop

ci-smoke-env:
	@echo noop
