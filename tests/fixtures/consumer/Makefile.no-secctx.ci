# Lint fixture contract variant: all required targets present, but no
# optional ci-secctx target — its absence must be a notice, not a violation.

SHELL := /bin/bash

.PHONY: ci-manifest ci-build ci-smoke-env

define CI_MANIFEST_JSON
{
  "images": [
    {"name": "backend", "dockerfile": "containers/backend/Dockerfile", "context": "."}
  ],
  "chart": {
    "path": "helm/app",
    "values": "helm/app/values.yaml",
    "values_local": "helm/app/values-local.yaml",
    "release": "app-ci",
    "namespace": "app-ci"
  },
  "health": {"path": "/health", "port": "8000", "workload_match": "backend"}
}
endef
export CI_MANIFEST_JSON

ci-manifest:
	@printf '%s\n' "$$CI_MANIFEST_JSON"

ci-build:
	@echo noop

ci-smoke-env:
	@echo noop
